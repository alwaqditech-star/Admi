rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Custom claims (set only via Cloud Functions Admin SDK) ──
    function signedIn() {
      return request.auth != null;
    }

    function currentUserRef() {
      return /databases/$(database)/documents/user/$(request.auth.uid);
    }

    function currentUserData() {
      return signedIn() ? get(currentUserRef()).data : {};
    }

    function claimBool(name) {
      return request.auth != null && request.auth.token[name] == true;
    }

    function isSuperAdmin() {
      return claimBool('super_admin')
        || currentUserData().IsAdmin == true
        || currentUserData().isAdmin == true
        || currentUserData().isAdminRule == 1
        || currentUserData().IsAdminRule == 1;
    }

    function isCountryAdmin() {
      return claimBool('country_admin')
        || currentUserData().isAdminRule == 2
        || currentUserData().IsAdminRule == 2;
    }

    function isAgent() {
      return claimBool('agent')
        || currentUserData().Isagent == true
        || currentUserData().isagent == true;
    }

    function isSupport() {
      return claimBool('support') || isSuperAdmin() || isCountryAdmin();
    }

    function isFinance() {
      return claimBool('finance') || isSuperAdmin() || isCountryAdmin();
    }

    function isPartner() {
      return claimBool('partner')
        || currentUserData().is_partner == true
        || currentUserData().isPartner == true
        || currentUserData().isAdminRule == 3
        || currentUserData().IsAdminRule == 3;
    }

    function isTransportManager() {
      return claimBool('transport_manager')
        || currentUserData().isAdminRule == 4
        || currentUserData().IsAdminRule == 4;
    }

    function isDriver() {
      return claimBool('driver') || currentUserData().ismndob == true;
    }

    function isApprovedActiveDriver() {
      return claimBool('driver')
        || (currentUserData().ismndob == true
            && currentUserData().actevMndob == true);
    }

    function isPanelUser() {
      return isSuperAdmin()
        || isCountryAdmin()
        || isAgent()
        || isSupport()
        || isFinance()
        || isPartner()
        || isTransportManager();
    }

    function claimCountryPath() {
      return signedIn() && request.auth.token.country_id != null
        ? request.auth.token.country_id
        : (
            currentUserData().Rev_dloh_agent != null
              ? currentUserData().Rev_dloh_agent.path
              : (
                  currentUserData().Rev_dolh != null
                    ? currentUserData().Rev_dolh.path
                    : null
                )
          );
    }

    function claimPartnerMkanPath() {
      return signedIn() && request.auth.token.partner_mkan_id != null
        ? request.auth.token.partner_mkan_id
        : (
            currentUserData().partner_mkan != null
              ? currentUserData().partner_mkan.path
              : null
          );
    }

    function claimTransportCompanyPath() {
      return signedIn() && request.auth.token.transport_company_id != null
        ? request.auth.token.transport_company_id
        : (
            currentUserData().transport_company != null
              ? currentUserData().transport_company.path
              : null
          );
    }

    function countryRefFromClaim() {
      return claimCountryPath() != null
        ? /databases/$(database)/documents/$(claimCountryPath())
        : null;
    }

    function countriesMatchAdminScope(countryRef) {
      return countryRef != null
        && claimCountryPath() != null
        && countryRef.path == claimCountryPath();
    }

    function orderBelongsToPartner(data) {
      return isPartner()
        && claimPartnerMkanPath() != null
        && data.partner_mkans != null
        && claimPartnerMkanPath() in data.partner_mkans;
    }

    function orderBelongsToConsumer(data) {
      return request.auth != null
        && !isPanelUser()
        && data.USER == /databases/$(database)/documents/user/$(request.auth.uid);
    }

    function orderAssignedToDriver(data) {
      return isDriver() && (
        data.mndob_user == currentUserRef()
        || (data.mzod_user != null && currentUserRef() in data.mzod_user)
      );
    }

    function transportCompanyMatches(data) {
      return isTransportManager()
        && claimTransportCompanyPath() != null
        && data.mndob_user != null
        && get(data.mndob_user).data.transport_company.path == claimTransportCompanyPath();
    }

    // Drivers must see open pool orders to accept them (C-04).
    function driverCanBrowseOpenOrders(data) {
      return isApprovedActiveDriver()
        && data.mndob_user == null
        && data.ALLNOW == true
        && (
          data.halh_order == 'Pending'
          || data.status_code == 'pending_driver'
          || data.status_code == 'awaiting_driver'
          || data.halh_text == 'بإنتظار قبول المندوب'
        );
    }

    function canReadOrder(data) {
      return isSuperAdmin()
        || isFinance()
        || (isCountryAdmin() && countriesMatchAdminScope(data.Rev_dolh))
        || (isAgent() && countriesMatchAdminScope(data.Rev_dolh))
        || (isSupport() && countriesMatchAdminScope(data.Rev_dolh))
        || orderBelongsToPartner(data)
        || transportCompanyMatches(data)
        || orderAssignedToDriver(data)
        || driverCanBrowseOpenOrders(data)
        || orderBelongsToConsumer(data);
    }

    function financialOrderFieldsUnchanged() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'USER', 'total', 'amount_halalas', 'currency', 'total_mndob',
        'total_mndob2', 'total_vat', 'total_app', 'ksm', 'SrSAAH',
        'PaymentMethod', 'ngeniusOrderId', 'idMoyser', 'payment_status',
        'payment_session_id', 'payment_verified_at', 'carRev', 'Rev_dolh',
        'total_taim', 'data_order'
      ]);
    }

    function consumerOrderFieldsOnly() {
      return orderBelongsToConsumer(resource.data)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'ReviewMndonsend', 'revewSendClent', 'RetengUser',
          'cancellation_requested', 'cancellation_reason',
          'cancellation_requested_at'
        ]);
    }

    function driverClaimKeysOnly() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'mndob_user', 'naim_mndob_text', 'phone_nu_mndob', 'carmndob',
        'halh_text', 'halhOrderMndob', 'ActiveOrder', 'START', 'mapuser',
        'timestamp', 'NameCar', 'ModelCar', 'status_code'
      ]);
    }

    // Atomic claim: unassigned → this driver only (C-04 / C-05).
    function driverCanClaimOrder() {
      return isApprovedActiveDriver()
        && resource.data.mndob_user == null
        && request.resource.data.mndob_user == currentUserRef()
        && financialOrderFieldsUnchanged()
        && driverClaimKeysOnly()
        && request.resource.data.status_code == 'driver_assigned'
        && request.resource.data.ActiveOrder == true;
    }

    // Assigned driver may advance trip state but never reassign or edit money.
    function driverCanAdvanceTrip() {
      return orderAssignedToDriver(resource.data)
        && request.resource.data.mndob_user == resource.data.mndob_user
        && financialOrderFieldsUnchanged()
        && !(request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['USER', 'PaymentMethod', 'carRev', 'Rev_dolh']));
    }

    // Cash complete may flip collection flags only — never totals/currency.
    function driverCanCompleteCashCollection() {
      return orderAssignedToDriver(resource.data)
        && request.resource.data.mndob_user == resource.data.mndob_user
        && resource.data.PaymentMethod == 'Cash'
        && request.resource.data.PaymentMethod == 'Cash'
        && request.resource.data.status_code == 'completed'
        && request.resource.data.ActiveOrder == false
        && request.resource.data.total == resource.data.total
        && request.resource.data.amount_halalas == resource.data.amount_halalas
        && request.resource.data.currency == resource.data.currency
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'USER', 'total', 'amount_halalas', 'currency', 'total_mndob',
          'total_mndob2', 'total_vat', 'total_app', 'ksm', 'SrSAAH',
          'ngeniusOrderId', 'idMoyser', 'payment_session_id', 'carRev',
          'Rev_dolh', 'total_taim', 'data_order'
        ])
        && request.resource.data.payment_status in ['cash_collected', 'paid']
        && request.resource.data.cash_collection_status == 'collected';
    }

    function panelCanWriteOrder(data) {
      return (
        isSuperAdmin()
        || (isCountryAdmin() && countriesMatchAdminScope(data.Rev_dolh))
        || (isSupport() && countriesMatchAdminScope(data.Rev_dolh))
        || orderBelongsToPartner(data)
        || transportCompanyMatches(data)
      ) && financialOrderFieldsUnchanged();
    }

    function operationsCanWriteOrder(data) {
      return panelCanWriteOrder(data)
        || driverCanClaimOrder()
        || driverCanAdvanceTrip()
        || driverCanCompleteCashCollection();
    }

    function privilegedUserFieldsUnchanged() {
      let d = request.resource.data;
      let prev = resource == null ? {} : resource.data;
      return d.get('isAdmin', prev.get('isAdmin', false)) == prev.get('isAdmin', false)
        && d.get('IsAdmin', prev.get('IsAdmin', false)) == prev.get('IsAdmin', false)
        && d.get('isAdminRule', prev.get('isAdminRule', 0)) == prev.get('isAdminRule', 0)
        && d.get('IsAdminRule', prev.get('IsAdminRule', 0)) == prev.get('IsAdminRule', 0)
        && d.get('isagent', prev.get('isagent', false)) == prev.get('isagent', false)
        && d.get('Isagent', prev.get('Isagent', false)) == prev.get('Isagent', false)
        && d.get('ismndob', prev.get('ismndob', false)) == prev.get('ismndob', false)
        && d.get('isPartner', prev.get('isPartner', false)) == prev.get('isPartner', false)
        && d.get('is_partner', prev.get('is_partner', false)) == prev.get('is_partner', false)
        && d.get('actevMndob', prev.get('actevMndob', false)) == prev.get('actevMndob', false)
        && d.get('Rev_dloh_agent', prev.get('Rev_dloh_agent', null)) == prev.get('Rev_dloh_agent', null)
        && d.get('partner_mkan', prev.get('partner_mkan', null)) == prev.get('partner_mkan', null)
        && d.get('transport_company', prev.get('transport_company', null)) == prev.get('transport_company', null);
    }

    function userSelfFieldsOnly() {
      return request.auth.uid == document
        && privilegedUserFieldsUnchanged();
    }

    function partnerOwnsMkan(mkanId) {
      return isPartner()
        && claimPartnerMkanPath() != null
        && claimPartnerMkanPath() == /databases/$(database)/documents/mkan/$(mkanId);
    }

  // ── Countries (super admin write; authenticated read) ──
    match /countries/{document} {
      allow read: if request.auth != null;
      allow create, update, delete: if isSuperAdmin();
    }

    match /cities/{document} {
      allow read: if request.auth != null;
      allow create: if isSuperAdmin()
        || (isCountryAdmin() && countriesMatchAdminScope(request.resource.data.dolh));
      allow update, delete: if isSuperAdmin()
        || (isCountryAdmin() && countriesMatchAdminScope(resource.data.dolh));
    }

    match /villages/{document} {
      allow read: if request.auth != null;
      allow create: if isSuperAdmin()
        || (isCountryAdmin() && countriesMatchAdminScope(request.resource.data.dolh));
      allow update, delete: if isSuperAdmin()
        || (isCountryAdmin() && countriesMatchAdminScope(resource.data.dolh));
    }

    match /user/{document} {
      allow create: if request.auth != null
        && request.auth.uid == document
        && !('isAdmin' in request.resource.data)
        && !('IsAdmin' in request.resource.data)
        && !('isAdminRule' in request.resource.data)
        && !('IsAdminRule' in request.resource.data)
        && !('isagent' in request.resource.data)
        && !('Isagent' in request.resource.data)
        && !('ismndob' in request.resource.data)
        && !('isPartner' in request.resource.data)
        && !('Rev_dloh_agent' in request.resource.data)
        && !('partner_mkan' in request.resource.data)
        && !('transport_company' in request.resource.data);
      allow read: if request.auth != null && (
        isSuperAdmin()
        || request.auth.uid == document
        || (isCountryAdmin() && countriesMatchAdminScope(resource.data.Rev_dloh_agent))
        || (isCountryAdmin() && countriesMatchAdminScope(resource.data.Rev_dolh))
        || (isTransportManager()
            && resource.data.transport_company != null
            && resource.data.transport_company.path == claimTransportCompanyPath())
      );
      allow update: if request.auth != null && (
        isSuperAdmin()
        || userSelfFieldsOnly()
        || (isCountryAdmin() && countriesMatchAdminScope(request.resource.data.Rev_dloh_agent))
      );
      allow delete: if isSuperAdmin();
    }

    match /user/{userId}/fcm_tokens/{tokenId} {
      allow read, create, update, delete: if signedIn()
        && request.auth.uid == userId;
    }

    match /transport_company/{document} {
      allow read: if request.auth != null && (
        isSuperAdmin()
        || isCountryAdmin()
        || (isTransportManager() && resource.path == claimTransportCompanyPath())
      );
      allow create: if isSuperAdmin() || isCountryAdmin();
      allow update, delete: if isSuperAdmin()
        || (isCountryAdmin() && countriesMatchAdminScope(resource.data.Rev_dolh))
        || (isTransportManager() && resource.path == claimTransportCompanyPath());
    }

    match /mkan/{document} {
      allow read: if request.auth != null;
      // Create: panel roles as before.
      allow create: if isSuperAdmin()
        || (isCountryAdmin() && countriesMatchAdminScope(request.resource.data.Rev_dolh))
        || (isAgent() && countriesMatchAdminScope(request.resource.data.Rev_dolh));
      // Update/delete: prefer custom claim to avoid get() recursion, then user doc flags.
      allow update, delete: if claimBool('super_admin')
        || (signedIn()
            && get(/databases/$(database)/documents/user/$(request.auth.uid)).data.get('IsAdmin', false) == true)
        || (signedIn()
            && get(/databases/$(database)/documents/user/$(request.auth.uid)).data.get('isAdminRule', 0) == 1)
        || (signedIn()
            && get(/databases/$(database)/documents/user/$(request.auth.uid)).data.get('IsAdminRule', 0) == 1)
        || (isCountryAdmin() && countriesMatchAdminScope(resource.data.Rev_dolh))
        || (isAgent() && countriesMatchAdminScope(resource.data.Rev_dolh))
        || partnerOwnsMkan(document);
    }

    match /Classification/{document} {
      allow read: if request.auth != null;
      allow write: if isSuperAdmin();
    }

    match /cart/{document} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    match /type_car/{document} {
      allow read: if request.auth != null;
      allow create, update, delete: if isSuperAdmin() || isCountryAdmin();
    }

    // Cash bookings must normally be created by createCashBooking CF.
    // Until that function is published (requires Cloud Billing), allow a
    // tightly constrained client create for pending cash only.
    // rules-rev: cash-fallback-2026-07-19
    function isValidClientCashOrderCreate() {
      let d = request.resource.data;
      return signedIn()
        && d.USER == currentUserRef()
        && d.PaymentMethod == 'Cash'
        && d.halh_order == 'Cash'
        && d.payment_status == 'cash_pending'
        && d.cash_collection_status == 'uncollected'
        && d.status_code == 'pending_driver'
        && d.ActiveOrder == false
        && d.created_by_client_cash_fallback == true
        && d.pricing_authority == 'client_fallback_pending_cf'
        && d.keys().hasAll([
          'USER', 'total', 'amount_halalas', 'currency', 'carRev', 'Rev_dolh',
          'PaymentMethod', 'payment_status', 'status_code', 'idempotency_key',
          'created_by_client_cash_fallback', 'pricing_authority',
          'pricing_quote_halalas'
        ])
        && d.total is number && d.total > 0 && d.total < 1000000
        && d.amount_halalas is int && d.amount_halalas > 0
        && d.amount_halalas == d.pricing_quote_halalas
        && d.currency is string
        && d.idempotency_key is string
        && d.idempotency_key.size() >= 8
        && d.idempotency_key.size() <= 96
        // Never allow client to mark paid / electronic statuses.
        && !(d.payment_status in ['paid', 'captured', 'authorized'])
        && !('ngeniusOrderId' in d)
        && !('payment_session_id' in d);
    }

    match /order/{document} {
      allow create: if isValidClientCashOrderCreate();
      allow read: if request.auth != null && canReadOrder(resource.data);
      allow update: if request.auth != null && (
        consumerOrderFieldsOnly() || operationsCanWriteOrder(resource.data)
      );
      allow delete: if false;
    }

    match /auto_num/{document} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    match /cart_maps/{document} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    match /mapmap/{document} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    match /order_mkss/{document} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    match /order/{parent}/mkss/{document} {
      allow read: if request.auth != null
        && canReadOrder(get(/databases/$(database)/documents/order/$(parent)).data);
      allow create: if false;
      allow update, delete: if false;
    }

    match /{path=**}/mkss/{document} {
      allow read: if false;
    }

    match /ADRESSUSER/{document} {
      allow read, update, delete: if signedIn()
        && resource.data.USER == currentUserRef();
      allow create: if signedIn()
        && request.resource.data.USER == currentUserRef();
    }

    match /listamaknorder/{document} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    match /order2/{document} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    match /order2/{parent}/mkan2/{document} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    match /{path=**}/mkan2/{document} {
      allow read: if request.auth != null;
    }

    match /user/{parent}/ordaercart/{document} {
      allow read, write, create, delete: if request.auth != null
        && request.auth.uid == parent;
    }

    match /list_address/{document} {
      allow read, update, delete: if signedIn()
        && resource.data.user == currentUserRef();
      allow create: if signedIn()
        && request.resource.data.user == currentUserRef();
    }

    match /idlistorder/{document} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    match /demodelet/{document} {
      allow read: if isSuperAdmin();
      allow write: if false;
    }

    match /support/{document} {
      allow create: if request.auth != null;
      allow read, update: if request.auth != null && (
        isSuperAdmin()
        || (isSupport() && countriesMatchAdminScope(resource.data.Rev_dolh))
        || (isCountryAdmin() && countriesMatchAdminScope(resource.data.Rev_dolh))
        || (resource.data.USER == /databases/$(database)/documents/user/$(request.auth.uid))
      );
      allow delete: if isSuperAdmin();
    }

    match /admin_audit_log/{document} {
      allow read: if isSuperAdmin();
      allow create, update, delete: if false;
    }

    match /Settings/{document} {
      allow read: if true;
      allow create, update, delete: if isSuperAdmin();
    }

    match /mndob/{document} {
      allow read: if signedIn();
      allow create, update, delete: if isSuperAdmin() || isCountryAdmin();
    }

    match /scond/{document} {
      allow read: if signedIn();
      allow create, update, delete: if isSuperAdmin();
    }

    match /admin_financial_cache/{document} {
      allow read: if isSuperAdmin() || isFinance() || isCountryAdmin();
      allow write: if false;
    }

    match /payment_sessions/{document} {
      allow read: if signedIn() && (
        resource.data.user_id == request.auth.uid || isFinance()
      );
      allow create, update, delete: if false;
    }

    match /PaymentMethods/{document} {
      allow read, delete: if signedIn()
        && resource.data.userRev == currentUserRef();
      allow create, update: if false;
    }

    match /wallets/{document} {
      allow read: if signedIn() && (
        resource.data.userRef == currentUserRef() || isFinance()
      );
      allow create, update, delete: if false;
    }

    match /transactions/{document} {
      allow read: if signedIn() && (
        resource.data.userRef == currentUserRef() || isFinance()
      );
      allow create, update, delete: if false;
    }

    match /wallet_withdrawals/{document} {
      allow read: if signedIn() && (
        resource.data.userRef == currentUserRef() || isFinance()
      );
      allow create, update, delete: if false;
    }

    match /Paymenthistory/{document} {
      allow read: if signedIn() && (
        resource.data.RevUser == currentUserRef() || isFinance()
      );
      allow create, update, delete: if false;
    }

    match /ExtraHours/{document} {
      allow read: if signedIn() && (
        resource.data.revUser == currentUserRef()
        || isFinance()
        || (resource.data.RevOrder != null
          && canReadOrder(get(resource.data.RevOrder).data))
      );
      allow create, update, delete: if false;
    }

    match /bank/{document} {
      allow read: if signedIn() && (
        isFinance()
        || resource.data.userRef == currentUserRef()
        || resource.data.RevUser == currentUserRef()
      );
      allow create, update, delete: if false;
    }

    match /ReviewsUser/{document} {
      allow read: if signedIn() && (
        resource.data.RevUser == currentUserRef()
        || resource.data.UserAlSend == currentUserRef()
        || isSupport()
      );
      allow create: if signedIn()
        && request.resource.data.UserAlSend == currentUserRef()
        && request.resource.data.orderRev != null
        && canReadOrder(get(request.resource.data.orderRev).data);
      allow update, delete: if false;
    }

    match /chat/{document} {
      allow read: if signedIn()
        && resource.data.idorder != null
        && canReadOrder(get(resource.data.idorder).data);
      allow create: if signedIn()
        && request.resource.data.user1 == currentUserRef()
        && request.resource.data.idorder != null
        && canReadOrder(get(request.resource.data.idorder).data);
      allow update, delete: if false;
    }

    match /locations/{document} {
      allow read: if false;
      allow create, update: if isDriver()
        && request.auth.uid == document
        && request.resource.data.userId == request.auth.uid;
      allow delete: if isDriver() && request.auth.uid == document;
    }

    match /E-paymentduerequests/{document} {
      allow read: if signedIn() && (
        resource.data.userRev == currentUserRef() || isFinance()
      );
      allow create, update, delete: if false;
    }

    match /ff_user_push_notifications/{id} {
      allow read, update, delete: if false;
      allow create: if signedIn()
        && request.resource.data.sender == currentUserRef()
        && request.resource.data.user_refs is string
        && request.resource.data.user_refs.size() > 0;
    }

    match /ff_push_notifications/{id} {
      allow read, create, update, delete: if false;
    }
  }
}
