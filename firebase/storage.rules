rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // قراءة عامة — تطبيق العميل يعرض الصور بدون تسجيل دخول
    // الكتابة — مستخدم مسجّل (مشرف/مستخدم)

    match /users/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /landmarks/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /countries/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /regions/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /cities/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /type_car/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /representatives/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /places/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
